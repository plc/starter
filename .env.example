# Environment variables for local development
#
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# Note: .env is gitignored and should never be committed

# Server port (generate deterministic port with: ./scripts/get-port.sh PROJECT_NAME)
PORT=3000

# Database: sqlite (default) or postgres
DB_TYPE=sqlite
SQLITE_PATH=./data/myapp.db

# -- Uncomment for PostgreSQL --
# DB_TYPE=postgres
# DATABASE_URL=postgres://plc:postgres@host.docker.internal:5432/myapp
# DB_NAME=myapp
