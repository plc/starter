# Environment variables for local development
#
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# Note: .env is gitignored and should never be committed

# App name (shown on status page)
APP_NAME=myapp

# Server port (generate deterministic port with: ./scripts/get-port.sh PROJECT_NAME)
PORT=3000

# Database: sqlite (default) or postgres
DB_TYPE=sqlite
SQLITE_PATH=./data/myapp.db

# -- Uncomment for PostgreSQL --
# DB_TYPE=postgres
# DB_NAME=myapp
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_PORT=5432
# Connect from host (psql, etc.): postgres://postgres:postgres@localhost:5432/myapp
